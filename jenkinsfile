pipeline {
    agent any

    environment {
        DOCKER_IMAGE = 'ajaydhadi95/booking-backend'
        REGISTRY_CREDENTIALS = 'dockerhub-creds'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ajaydhadi95-gif/Booking_app_backend.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    // Yahan path wapas '.' (root) kar diya hai
                    sh "docker build -t ${DOCKER_IMAGE}:${BUILD_NUMBER} -t ${DOCKER_IMAGE}:latest ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                withCredentials([usernamePassword(credentialsId: REGISTRY_CREDENTIALS, passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                    sh "docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('Deploy to K3s') {
            steps {
                script {
                    echo "Applying Kubernetes manifests..."
                    // Yahan bhi path se Backend/ hata diya hai
                    sh "kubectl apply -f k8s/deployment.yaml"
                    sh "kubectl apply -f k8s/service.yaml"
                    
                    echo "Triggering Kubernetes rolling update..."
                    sh "kubectl set image deployment/booking-backend-deployment booking-backend=${DOCKER_IMAGE}:${BUILD_NUMBER}"
                    
                    echo "Checking rollout status..."
                    sh "kubectl rollout status deployment/booking-backend-deployment --timeout=60s"
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning up intermediate local images..."
            sh "docker rmi ${DOCKER_IMAGE}:${BUILD_NUMBER} || true"
        }
        success {
            echo "Backend application rolled out seamlessly to K3s cluster!"
        }
        failure {
            echo "Kubernetes backend deployment failed."
        }
    }
}